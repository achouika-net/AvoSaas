generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Center {
  id        String       @id @default(uuid())
  name      String
  address   String?
  geminiApiKey String?
  createdAt DateTime     @default(now())
  cases     Case[]
  clients   Client[]
  users     UserCenter[]
  libraryMemos LibraryMemo[]
}

model User {
  id        String       @id @default(uuid())
  name      String
  email     String       @unique
  password  String
  role      String       @default("LAWYER")
  createdAt DateTime     @default(now())
  centers   UserCenter[]
}

model UserCenter {
  userId   String
  centerId String
  center   Center @relation(fields: [centerId], references: [id])
  user     User   @relation(fields: [userId], references: [id])

  @@id([userId, centerId])
}

model Client {
  id             String    @id @default(uuid())
  name           String
  type           String
  identityNumber String?
  phone          String?
  email          String?
  address        String?
  status         String    @default("ACTIVE")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  centerId       String
  cases          Case[]
  center         Center    @relation(fields: [centerId], references: [id])
  invoices       Invoice[]
}

model Case {
  id                 String        @id @default(uuid())
  title              String
  type               String
  courtName          String
  opponentName       String?
  primaryNumber      String?
  appealNumber       String?
  supremeCourtNumber String?
  opponentLawyerName  String?
  opponentLawyerOffice String?
  agreedFees          Float?        @default(0)
  narrative           String?
  legalMemo           String?
  status             String        @default("ONGOING")
  currentStage       String        @default("FIRST_INSTANCE")
  clientId           String
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  centerId           String
  appointments       Appointment[]
  center             Center        @relation(fields: [centerId], references: [id])
  client             Client        @relation(fields: [clientId], references: [id])
  documents          Document[]
  expenses           Expense[]
  invoices           Invoice[]
}

model Appointment {
  id          String   @id @default(uuid())
  title       String
  date        DateTime
  type        String
  caseId      String?
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  case        Case?    @relation(fields: [caseId], references: [id])
}

model Document {
  id        String   @id @default(uuid())
  title     String
  content   String
  caseId    String
  createdAt DateTime @default(now())
  case      Case     @relation(fields: [caseId], references: [id])
}

model Expense {
  id        String   @id @default(uuid())
  title     String
  amount    Float
  type      String
  caseId    String
  createdAt DateTime @default(now())
  case      Case     @relation(fields: [caseId], references: [id])
}

model Invoice {
  id        String   @id @default(uuid())
  amount    Float
  status    String   @default("UNPAID")
  type      String   @default("FEES") // FEES, EXPENSE, PREPAYMENT
  description String?
  clientId  String
  caseId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  client    Client   @relation(fields: [clientId], references: [id])
  case      Case?    @relation(fields: [caseId], references: [id])
}

model Law {
  id            String   @id @default(uuid())
  codeName      String   // e.g., "مدونة الشغل", "قانون المسطرة المدنية"
  articleNumber String   // e.g., "المادة 62"
  content       String   // Full authentic Arabic text
  category      String?  // CIVIL, LABOUR, CRIMINAL, etc.
  keywords      String?  // SPACE separated keywords for search
  createdAt     DateTime @default(now())
}

model LibraryMemo {
  id            String   @id @default(uuid())
  title         String
  content       String
  category      String   // e.g., "DIVORCE", "COMMERCIAL"
  centerId      String
  center        Center   @relation(fields: [centerId], references: [id])
  filePath      String?  // Local file path relative to scanning folder
  lastModified  DateTime? // To detect file changes
  createdAt     DateTime @default(now())
}

model SyncJob {
  id            String   @id @default(uuid())
  centerId      String   @unique
  isSyncing     Boolean  @default(false)
  scanned       Int      @default(0)
  total         Int      @default(0)
  new           Int      @default(0)
  updated       Int      @default(0)
  errors        Int      @default(0)
  lastSync      DateTime?
  updatedAt     DateTime @updatedAt
}
